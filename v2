4. If time limit is set, it will auto-stop.
5. Click 'Stop' to end manually.

Tips:
- Hover over controls for tooltips.
- Ensure inputs are valid numbers.
- Hotkey works globally when running.
"@, "Help")
    })

    Function Start-Clicking {
        try {
            # Validation
            $intervalVal = 0.0
            if (-not [float]::TryParse($textInterval.Text, [ref]$intervalVal) -or $intervalVal -le 0) {
                throw "Invalid interval: must be positive number"
            }
            $randomizeVal = 0.0
            if (-not [float]::TryParse($textRandomize.Text, [ref]$randomizeVal) -or $randomizeVal -lt 0) {
                throw "Invalid randomize: must be non-negative number"
            }
            $clickTypeVal = 1
            if (-not [int]::TryParse($textClickType.Text, [ref]$clickTypeVal) -or $clickTypeVal -lt 1) {
                throw "Invalid click type: must be positive integer"
            }
            $holdTimeVal = 0.0
            if (-not [float]::TryParse($textHoldTime.Text, [ref]$holdTimeVal) -or $holdTimeVal -lt 0) {
                throw "Invalid hold time: must be non-negative number"
            }
            $randomOffsetVal = 0
            if (-not [int]::TryParse($textRandomOffset.Text, [ref]$randomOffsetVal) -or $randomOffsetVal -lt 0) {
                throw "Invalid random offset: must be non-negative integer"
            }
            $clicksVal = -1
            if (-not $checkInfinite.Checked) {
                if (-not [int]::TryParse($textClicks.Text, [ref]$clicksVal) -or $clicksVal -le 0) {
                    throw "Invalid clicks: must be positive integer"
                }
            }
            $xVal = -1
            $yVal = -1
            if ($radioFixed.Checked) {
                if (-not [int]::TryParse($textX.Text, [ref]$xVal)) {
                    throw "Invalid X coordinate"
                }
                if (-not [int]::TryParse($textY.Text, [ref]$yVal)) {
                    throw "Invalid Y coordinate"
                }
            }
            $totalSecondsVal = 0
            if ($checkTimeLimit.Checked) {
                $hours = 0; $mins = 0; $secs = 0
                if (-not [int]::TryParse($textHours.Text, [ref]$hours) -or $hours -lt 0) { throw "Invalid hours" }
                if (-not [int]::TryParse($textMinutes.Text, [ref]$mins) -or $mins -lt 0 -or $mins -gt 59) { throw "Invalid minutes" }
                if (-not [int]::TryParse($textSeconds.Text, [ref]$secs) -or $secs -lt 0 -or $secs -gt 59) { throw "Invalid seconds" }
                $totalSecondsVal = $hours * 3600 + $mins * 60 + $secs
                if ($totalSecondsVal -le 0) { throw "Time limit must be greater than 0" }
            }

            $buttonVal = $comboButton.SelectedItem
            $hotkeyVal = $comboHotkey.SelectedItem
            $vk = switch ($hotkeyVal) {
                "F1" { 112 }
                "F2" { 113 }
                "F3" { 114 }
                "F4" { 115 }
                "F5" { 116 }
                "F6" { 117 }
                "F7" { 118 }
                "F8" { 119 }
                "F9" { 120 }
                "F10" { 121 }
                "F11" { 122 }
                "F12" { 123 }
            }
            [Mouse]::RegisterHotKey($form.Handle, 1, 0, $vk)

            $script:job = Start-Job -ScriptBlock {
                param($interval, $button, $clicks, $x, $y, $randomize, $clickType, $holdTime, $randomOffset, $totalSeconds)

                Add-Type -TypeDefinition @"
using System;
using System.Runtime.InteropServices;
public class Mouse {
    [DllImport("user32.dll")]
    public static extern void mouse_event(uint dwFlags, uint dx, uint dy, uint dwData, IntPtr dwExtraInfo);
    [DllImport("user32.dll")]
    public static extern bool SetCursorPos(int x, int y);
    public const uint MOUSEEVENTF_LEFTDOWN = 0x02;
    public const uint MOUSEEVENTF_LEFTUP = 0x04;
    public const uint MOUSEEVENTF_RIGHTDOWN = 0x08;
    public const uint MOUSEEVENTF_RIGHTUP = 0x10;
    public const uint MOUSEEVENTF_MIDDLEDOWN = 0x20;
    public const uint MOUSEEVENTF_MIDDLEUP = 0x40;
}
"@

                Function Click-Mouse {
                    param([string]$button = "left", [float]$hold = 0)
                    switch ($button) {
                        "left" {
                            [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTDOWN, 0, 0, 0, [IntPtr]::Zero)
                            if ($hold -gt 0) { Start-Sleep -Seconds $hold }
                            [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)
                        }
                        "right" {
                            [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_RIGHTDOWN, 0, 0, 0, [IntPtr]::Zero)
                            if ($hold -gt 0) { Start-Sleep -Seconds $hold }
                            [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_RIGHTUP, 0, 0, 0, [IntPtr]::Zero)
                        }
                        "middle" {
                            [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_MIDDLEDOWN, 0, 0, 0, [IntPtr]::Zero)
                            if ($hold -gt 0) { Start-Sleep -Seconds $hold }
                            [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_MIDDLEUP, 0, 0, 0, [IntPtr]::Zero)
                        }
                    }
                }

                $stopwatch = if ($totalSeconds -gt 0) { [System.Diagnostics.Stopwatch]::StartNew() } else { $null }
                $count = 0
                while ($true) {
                    if ($totalSeconds -gt 0 -and $stopwatch.Elapsed.TotalSeconds -ge $totalSeconds) { break }
                    if ($randomOffset -gt 0) {
                        $rx = Get-Random -Min (-$randomOffset) -Max $randomOffset
                        $ry = Get-Random -Min (-$randomOffset) -Max $randomOffset
                        $cx = if ($x -ne -1) { $x + $rx } else { -1 }
                        $cy = if ($y -ne -1) { $y + $ry } else { -1 }
                    } else {
                        $cx = $x
                        $cy = $y
                    }
                    if ($cx -ne -1 -and $cy -ne -1) {
                        [Mouse]::SetCursorPos($cx, $cy)
                    }
                    for ($i = 0; $i -lt $clickType; $i++) {
                        Click-Mouse -button $button -hold $holdTime
                        if ($i -lt $clickType - 1) { Start-Sleep -Milliseconds 100 }
                    }
                    $count++
                    if ($clicks -ne -1 -and $count -ge $clicks) { break }
                    $sleepTime = $interval + (Get-Random -Minimum 0 -Maximum $randomize)
                    Start-Sleep -Seconds $sleepTime
                }
            } -ArgumentList $intervalVal, $buttonVal, $clicksVal, $xVal, $yVal, $randomizeVal, $clickTypeVal, $holdTimeVal, $randomOffsetVal, $totalSecondsVal

            $labelStatus.Text = "Running..."
        } catch {
            [System.Windows.Forms.MessageBox]::Show("Error: " + $_.Exception.Message, "Input Error")
        }
    }

    Function Toggle-Clicking {
        if ($script:job) {
            Stop-Job $script:job -ErrorAction SilentlyContinue
            Remove-Job $script:job -ErrorAction SilentlyContinue
            $script:job = $null
            $labelStatus.Text = "Stopped"
            [Mouse]::UnregisterHotKey($form.Handle, 1)
        } else {
            Start-Clicking
        }
    }

    $buttonStart.Add_Click({ Start-Clicking })

    $buttonStop.Add_Click({
        if ($script:job) {
            Stop-Job $script:job -ErrorAction SilentlyContinue
            Remove-Job $script:job -ErrorAction SilentlyContinue
            $script:job = $null
        }
        $labelStatus.Text = "Stopped"
        [Mouse]::UnregisterHotKey($form.Handle, 1)
    })

    $form.Add_WndProc({
        param($m)
        if ($m.Msg -eq [Mouse]::WM_HOTKEY) {
            Toggle-Clicking
        }
    })

    [void]$form.ShowDialog()
} else {
    # CLI Mode
    Write-Host "Autoclicker started. Press Ctrl+C to stop."
    $count = 0
    while ($true) {
        # Calculate position with random offset
        if ($randomOffset -gt 0) {
            $rx = Get-Random -Min (-$randomOffset) -Max $randomOffset
            $ry = Get-Random -Min (-$randomOffset) -Max $randomOffset
            $cx = if ($x -ne -1) { $x + $rx } else { -1 }
            $cy = if ($y -ne -1) { $y + $ry } else { -1 }
        } else {
            $cx = $x
            $cy = $y
        }
        if ($cx -ne -1 -and $cy -ne -1) {
            [Mouse]::SetCursorPos($cx, $cy)
        }
        for ($i = 0; $i -lt $clickType; $i++) {
            Click-Mouse -button $button -hold $holdTime
            if ($i -lt $clickType - 1) { Start-Sleep -Milliseconds 100 }  # small delay for multi-click
        }
        $count++
        if ($clicks -ne -1 -and $count -ge $clicks) { break }
        $sleepTime = $interval + (Get-Random -Minimum 0 -Maximum $randomize)
        Start-Sleep -Seconds $sleepTime
    }
}
