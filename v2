    $form.Controls.Add($buttonStop)

    # Help Button
    $buttonHelp = New-Object System.Windows.Forms.Button
    $buttonHelp.Text = "Help"
    $buttonHelp.Location = New-Object System.Drawing.Point(190, 380)
    $buttonHelp.Size = New-Object System.Drawing.Size(80, 30)
    $form.Controls.Add($buttonHelp)
    $tooltip.SetToolTip($buttonHelp, "Show help information.")

    $buttonHelp.Add_Click({
        [System.Windows.Forms.MessageBox]::Show(@"
Autoclicker Help:

1. Configure your settings (interval, button, etc.).
