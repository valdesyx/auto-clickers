public class FischDetector {
    public static Rectangle FindFishBar(Bitmap bmp) {
        // Look for white rectangular area (fish bar)
        for (int y = 0; y < bmp.Height - 50; y++) {
            for (int x = 0; x < bmp.Width - 200; x++) {
                if (IsWhitePixel(bmp.GetPixel(x, y))) {
                    // Check if this is start of a white rectangle
                    int width = 0;
                    while (x + width < bmp.Width && IsWhitePixel(bmp.GetPixel(x + width, y))) {
                        width++;
                    }
                    if (width > 150) { // Minimum bar width
                        int height = 0;
                        while (y + height < bmp.Height && IsWhitePixel(bmp.GetPixel(x, y + height))) {
                            height++;
                        }
                        if (height > 10) { // Minimum bar height
                            return new Rectangle(x, y, width, height);
                        }
                    }
                }
            }
        }
        return Rectangle.Empty;
    }

    public static int FindVerticalLine(Bitmap bmp, Rectangle bar) {
        // Look for vertical line within the bar
        for (int x = bar.X; x < bar.X + bar.Width; x++) {
            bool isLine = true;
            for (int y = bar.Y; y < bar.Y + bar.Height; y++) {
                Color pixel = bmp.GetPixel(x, y);
                if (!IsDarkPixel(pixel)) {
                    isLine = false;
                    break;
                }
            }
            if (isLine) {
                return x;
            }
        }
        return -1;
    }

    public static int FindFishPosition(Bitmap bmp, Rectangle bar) {
        // Look for the fish (white rectangle within bar)
        for (int x = bar.X; x < bar.X + bar.Width - 20; x++) {
            for (int y = bar.Y; y < bar.Y + bar.Height; y++) {
                if (IsWhitePixel(bmp.GetPixel(x, y))) {
                    // Check if this forms a small white rectangle (fish)
                    int fishWidth = 0;
                    while (x + fishWidth < bar.X + bar.Width && IsWhitePixel(bmp.GetPixel(x + fishWidth, y))) {
                        fishWidth++;
                    }
                    if (fishWidth > 5 && fishWidth < 30) {
                        return x + fishWidth / 2; // Center of fish
                    }
                }
            }
        }
        return -1;
    }

    private static bool IsWhitePixel(Color c) {
        return c.R > 200 && c.G > 200 && c.B > 200;
    }

    private static bool IsDarkPixel(Color c) {
        return c.R < 100 && c.G < 100 && c.B < 100;
    }
}
