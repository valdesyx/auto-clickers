                Function Execute-Move($seq) {
                    $parts = $seq -split ','
                    foreach ($part in $parts) {
                        $key, $time = $part.Trim() -split ':'
                        $vk = switch ($key.ToUpper()) {
                            "W" { 0x57 }
                            "A" { 0x41 }
                            "S" { 0x53 }
                            "D" { 0x44 }
                            "Q" { 0x51 }
                            "E" { 0x45 }
                            "SPACE" { 0x20 }
                        }
                        if ($vk) {
                            [Mouse]::keybd_event($vk, 0, 0, [UIntPtr]::Zero)
                            Start-Sleep -Seconds [float]$time
                            [Mouse]::keybd_event($vk, 0, 2, [UIntPtr]::Zero)
                        }
                    }
                }

                $stopwatch = if ($totalSeconds -gt 0) { [System.Diagnostics.Stopwatch]::StartNew() } else { $null }
                while ($true) {
                    if ($totalSeconds -gt 0 -and $stopwatch.Elapsed.TotalSeconds -ge $totalSeconds) { break }

                    # Cast
                    [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_RIGHTDOWN, 0, 0, 0, [IntPtr]::Zero)
                    Start-Sleep -Seconds $castHold
                    [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_RIGHTUP, 0, 0, 0, [IntPtr]::Zero)

                    # Wait for bite
                    $wait = $waitMin + (Get-Random -Minimum 0 -Maximum ($waitMax - $waitMin))
                    Start-Sleep -Seconds $wait

                    # Reel
                    if ($smartReel) {
                        # Smart reeling - detect fish bar and keep aligned
                        $reeling = $true
                        $lastDirection = 0  # 0 = none, 1 = reel in, 2 = let out
                        $startTime = Get-Date
                        
                        while ($reeling -and ((Get-Date) - $startTime).TotalSeconds -lt 30) {  # Max 30 seconds
                            try {
                                # Capture screen (adjust coordinates as needed)
                                $bmp = [ScreenCapture]::CaptureScreen(0, 0, 1920, 1080)  # Full screen, adjust resolution
                                
                                # Find fish bar
                                $bar = [FischDetector]::FindFishBar($bmp)
                                if ($bar.Width -gt 0) {
                                    # Find vertical line
                                    $linePos = [FischDetector]::FindVerticalLine($bmp, $bar)
                                    if ($linePos -gt 0) {
                                        # Find fish position
                                        $fishPos = [FischDetector]::FindFishPosition($bmp, $bar)
                                        if ($fishPos -gt 0) {
                                            if ($fishPos -lt $linePos - 10) {
                                                # Fish is left of line - reel in (hold left click)
                                                if ($lastDirection -ne 1) {
                                                    [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)
                                                    [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTDOWN, 0, 0, 0, [IntPtr]::Zero)
                                                    $lastDirection = 1
                                                }
                                            } elseif ($fishPos -gt $linePos + 10) {
                                                # Fish is right of line - let out (release left click)
                                                if ($lastDirection -ne 2) {
                                                    [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)
                                                    $lastDirection = 2
                                                }
                                            } else {
                                                # Fish is aligned - release
                                                if ($lastDirection -ne 0) {
                                                    [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)
                                                    $lastDirection = 0
                                                }
                                            }
                                        }
                                    }
                                }
                                
                                $bmp.Dispose()
                                
                                # Check if mini-game ended (no bar found for a few seconds)
                                if ($bar.Width -eq 0) {
                                    $reeling = $false
                                }
                                
                                Start-Sleep -Milliseconds 50  # Check every 50ms
                            } catch {
                                # If detection fails, fall back to simple reeling
                                [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTDOWN, 0, 0, 0, [IntPtr]::Zero)
                                Start-Sleep -Milliseconds 100
                                [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)
                                $reeling = $false
                            }
                        }
                        
                        # Ensure left click is released
                        [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)
                    } else {
                        # Simple reeling
                        [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTDOWN, 0, 0, 0, [IntPtr]::Zero)
                        Start-Sleep -Milliseconds 100
                        [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)
                    }

                    # Auto move if enabled
                    if ($autoMove) { Execute-Move $moveSeq }

                    # Wait before next cast
                    Start-Sleep -Seconds $betweenCasts
                }
            } -ArgumentList $castHoldVal, $waitMinVal, $waitMaxVal, $betweenCastsVal, $totalSecondsVal, $autoMoveVal, $moveSeqVal, $smartReelVal

            $labelStatus.Text = "Running..."
        } catch {
            [System.Windows.Forms.MessageBox]::Show("Error: " + $_.Exception.Message, "Input Error")
        }
    }

    Function Toggle-Fishing {
        if ($script:job) {
            Stop-Job $script:job -ErrorAction SilentlyContinue
            Remove-Job $script:job -ErrorAction SilentlyContinue
            $script:job = $null
            $labelStatus.Text = "Stopped"
            [Mouse]::UnregisterHotKey($form.Handle, 1)
        } else {
            Start-Fishing
        }
    }

    $buttonStart.Add_Click({ Start-Fishing })

    $buttonStop.Add_Click({
        if ($script:job) {
            Stop-Job $script:job -ErrorAction SilentlyContinue
            Remove-Job $script:job -ErrorAction SilentlyContinue
            $script:job = $null
        }
        $labelStatus.Text = "Stopped"
        [Mouse]::UnregisterHotKey($form.Handle, 1)
    })

    $form.Add_WndProc({
        param($m)
        if ($m.Msg -eq [Mouse]::WM_HOTKEY) {
            Toggle-Fishing
        }
    })

    [void]$form.ShowDialog()
} else {
    # CLI Mode
    Write-Host "Fisch Macro started. Press Ctrl+C to stop."
    while ($true) {
        # Cast
        [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_RIGHTDOWN, 0, 0, 0, [IntPtr]::Zero)
        Start-Sleep -Seconds $castHold
        [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_RIGHTUP, 0, 0, 0, [IntPtr]::Zero)

        # Wait for bite
        $wait = $waitMin + (Get-Random -Minimum 0 -Maximum ($waitMax - $waitMin))
        Start-Sleep -Seconds $wait

        # Reel
        [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTDOWN, 0, 0, 0, [IntPtr]::Zero)
        Start-Sleep -Milliseconds 100
        [Mouse]::mouse_event([Mouse]::MOUSEEVENTF_LEFTUP, 0, 0, 0, [IntPtr]::Zero)

        # Wait before next cast
        Start-Sleep -Seconds $betweenCasts
    }
}
